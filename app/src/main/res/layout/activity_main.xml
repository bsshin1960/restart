<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="@string/main_title"
            android:textColor="@color/text_main"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center_horizontal" />

        <!-- Mode Selection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_title"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <RadioGroup
                    android:id="@+id/rgMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbAccessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="20dp"
                        android:text="@string/mode_accessibility"
                        android:textColor="@color/text_main"
                        android:textSize="12sp"
                        app:useMaterialThemeColors="true"
                        android:checked="true"/>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbAdb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_adb"
                        android:textColor="@color/text_main"
                        android:textSize="12sp"
                        app:useMaterialThemeColors="true"/>
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Authority Status & Execution Card (권한 상태 및 실행) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_title"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- Accessibility Status Row -->
                <LinearLayout
                    android:id="@+id/layoutAccessibilityStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="3dp"
                    android:layout_marginBottom="2dp">

                    <View
                        android:id="@+id/indicatorAccessibility"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/accessibility_status_label"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvAccessibilityStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/accessibility_denied"
                        android:textColor="@color/accent_red"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- ADB Status Row -->
                <LinearLayout
                    android:id="@+id/layoutAdbStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="3dp"
                    android:layout_marginBottom="8dp">

                    <View
                        android:id="@+id/indicatorAdb"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_indicator_red"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dpm_status_label"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvAdbStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dpm_inactive"
                        android:textColor="@color/accent_red"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="8dp"/>

                <!-- Accessibility Action Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRebootAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_reboot_accessibility_need"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="8dp"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="6dp"
                    app:rippleColor="#80FFFFFF"/>

                <!-- ADB Action Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRebootDpm"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_reboot_dpm_need"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="8dp"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    app:rippleColor="#80FFFFFF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Restart Reservation Card (재시작 예약) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/schedule_title"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/schedule_switch_label"
                        android:textColor="@color/text_main"
                        android:textSize="12sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSchedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:useMaterialThemeColors="true" />
                </LinearLayout>

                <!-- Day of Week Selector Row -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="예약 요일 선택"
                    android:textColor="@color/text_sub"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>

                <!-- Configured 15dp gap between buttons, size reduced to 30dp to guarantee it fits on all screens -->
                <LinearLayout
                    android:id="@+id/layoutDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDaySun"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="0dp"
                        android:text="일"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="15dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        android:textColor="@color/text_sub"
                        app:cornerRadius="15dp"
                        android:checkable="true"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDayMon"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="0dp"
                        android:text="월"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="15dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        android:textColor="@color/text_sub"
                        app:cornerRadius="15dp"
                        android:checkable="true"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDayTue"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="0dp"
                        android:text="화"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="15dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        android:textColor="@color/text_sub"
                        app:cornerRadius="15dp"
                        android:checkable="true"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDayWed"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="0dp"
                        android:text="수"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="15dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        android:textColor="@color/text_sub"
                        app:cornerRadius="15dp"
                        android:checkable="true"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDayThu"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="0dp"
                        android:text="목"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="15dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        android:textColor="@color/text_sub"
                        app:cornerRadius="15dp"
                        android:checkable="true"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDayFri"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="0dp"
                        android:text="금"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="15dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        android:textColor="@color/text_sub"
                        app:cornerRadius="15dp"
                        android:checkable="true"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDaySat"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="0dp"
                        android:text="토"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        android:textColor="@color/text_sub"
                        app:cornerRadius="15dp"
                        android:checkable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutTimePicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/schedule_time_label"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvSelectedTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="03:00"
                        android:textColor="@color/secondary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="3dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvScheduleInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/schedule_info_disabled"
                    android:textColor="@color/text_sub"
                    android:textSize="11sp"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
